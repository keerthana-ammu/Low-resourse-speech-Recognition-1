      "source": [
        "import numpy as np\n",
        "\n",
        "# Ensure the speech waveform is a 1-dimensional tensor and convert to numpy\n",
        "speech_numpy = speech.numpy()\n",
        "\n",
        "# Preprocess the audio file\n",
        "inputs = processor(speech_numpy, return_tensors=\"pt\", sampling_rate=16000)\n",
        "\n",
        "# Inference - Convert audio to text\n",
        "with torch.no_grad():\n",
        "    logits = model(input_values=inputs.input_values).logits\n",
        "\n",
        "# Get predicted IDs and decode them into text\n",
        "predicted_ids = torch.argmax(logits, dim=-1)\n",
        "transcription = processor.batch_decode(predicted_ids)\n",
        "\n",
        "print(\"Transcription:\", transcription[0])"
      ]
