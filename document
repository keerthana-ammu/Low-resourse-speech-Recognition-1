      "source": [
        "import torchaudio\n",
        "\n",
        "# Load audio using torchaudio and get its sampling rate\n",
        "speech, current_sampling_rate = torchaudio.load(audio_file)\n",
        "\n",
        "# Check if resampling is needed\n",
        "if current_sampling_rate != 16000:\n",
        "    resampler = torchaudio.transforms.Resample(orig_freq=current_sampling_rate, new_freq=16000)\n",
        "    speech = resampler(speech)\n",
        "\n",
        "# Ensure the speech waveform is a 1-dimensional tensor\n",
        "speech = speech.squeeze()"
      ]
    },
